{
  "version": 2,
  "builds": [
    {
      "src": "cms/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/staticfiles/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "cms/wsgi.py"
    }
  ]
}
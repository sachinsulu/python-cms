{
  "version": 2,
  "builds": [
    {
      "src": "cms/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "staticfiles/(.*)",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/staticfiles/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "cms/wsgi.py"
    }
  ]
}